<UserControl x:Class="BankingEcosystem.Admin.UI.Views.MbankingListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Main Content -->
        <Grid Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16"
                        VerticalAlignment="Center">
                <TextBlock Text="📱" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Manajemen Akun MBanking" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Search Row -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}" Height="36"
                         Tag="Cari nama, email, nomor rekening, nomor kartu..."
                         Margin="0,0,8,0" />

                <Button Grid.Column="1" Content="🔄 Refresh" Command="{Binding LoadCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Height="36" Width="100" />
            </Grid>

            <!-- DataGrid -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding Accounts}" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single" CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      Background="White" RowBackground="White" AlternatingRowBackground="#F8F9FA"
                      BorderBrush="#E0E0E0" BorderThickness="1"
                      FontSize="13" RowHeight="40" ColumnHeaderHeight="38">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="12,6" />
                        <Setter Property="BorderBrush" Value="#2C3E50" />
                        <Setter Property="BorderThickness" Value="0,0,1,0" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="12,6" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#D6EAF8" />
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- Nama Nasabah -->
                    <DataGridTextColumn Header="Nama Nasabah" Binding="{Binding CustomerName}" Width="*" />
                    <!-- Email MBanking -->
                    <DataGridTextColumn Header="Email MBanking" Binding="{Binding Email}" Width="180" />
                    <!-- No Rekening -->
                    <DataGridTextColumn Header="No Rekening" Binding="{Binding AccountNumber}" Width="130" />
                    <!-- No Kartu (masked) -->
                    <DataGridTextColumn Header="No Kartu" Binding="{Binding CardNumber}" Width="160" />
                    <!-- Tanggal Daftar -->
                    <DataGridTextColumn Header="Terdaftar" Binding="{Binding RegisteredAt, StringFormat=dd MMM yyyy HH:mm}" Width="140" />
                    <!-- Aksi -->
                    <DataGridTemplateColumn Header="Aksi" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <!-- Edit Email -->
                                    <Button Content="✏ Edit"
                                            Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            FontSize="11" Padding="8,3" Margin="0,0,6,0"
                                            Background="{StaticResource AccentBrush}" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" />
                                    <!-- Delete -->
                                    <Button Content="🗑 Hapus"
                                            Command="{Binding DataContext.DeleteAccountCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            FontSize="11" Padding="8,3"
                                            Background="#E74C3C" Foreground="White"
                                            BorderThickness="0" Cursor="Hand" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading Overlay -->
            <Border Grid.Row="2" Background="#80FFFFFF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock Text="Memuat data..." FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource SubtextBrush}" />
            </Border>
        </Grid>

        <!-- Edit Email Dialog Overlay -->
        <Grid Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVisConverter}}">
            <!-- Dim background -->
            <Border Background="#88000000" />

            <!-- Dialog Card -->
            <Border Background="White" CornerRadius="12" Padding="32"
                    MaxWidth="420" MaxHeight="280"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="24" Opacity="0.3" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="✏ Edit Email MBanking" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,20">
                        <Run Text="Nasabah: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SelectedAccount.CustomerName}"/>
                    </TextBlock>

                    <!-- Email Input -->
                    <TextBlock Text="Email Baru" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBoxStyle}" Height="38"
                             Tag="Email baru..." />

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="Batal" Command="{Binding CancelEditCommand}"
                                Width="90" Height="36" Margin="0,0,12,0"
                                Background="#ECF0F1" Foreground="#555" BorderThickness="0"
                                Cursor="Hand" />
                        <Button Content="Simpan" Command="{Binding SaveEmailCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="100" Height="36" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</UserControl>
